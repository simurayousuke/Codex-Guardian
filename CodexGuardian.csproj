<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>CodexGuardian</AssemblyName>
    <RootNamespace>CodexGuardian</RootNamespace>
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Assets\AppIcon.ico" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <Target Name="GenerateAppIcon" BeforeTargets="BeforeBuild" Condition="!Exists('Assets\AppIcon.ico') and Exists('Assets\AppIcon.ico.b64')">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$b64 = Get-Content -Raw '$(MSBuildProjectDirectory)\Assets\AppIcon.ico.b64'; [System.IO.File]::WriteAllBytes('$(MSBuildProjectDirectory)\Assets\AppIcon.ico', [System.Convert]::FromBase64String($b64))&quot;" />
  </Target></Project>
